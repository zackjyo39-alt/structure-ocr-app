# Copy to .env in this directory (deploy/.env) and adjust for your host.
# start-openviking-ollama.sh loads deploy/.env automatically if present.

# Ollama OpenAI-compatible API (must end with /v1)
# Local:
#   OLLAMA_API_BASE=http://127.0.0.1:11434/v1
# Same machine, listen on all interfaces (e.g. Docker / reverse proxy):
#   OLLAMA_API_BASE=http://127.0.0.1:11434/v1
# Remote Ollama on another host (VPS / LAN):
#   OLLAMA_API_BASE=http://10.0.0.5:11434/v1

OLLAMA_API_BASE=http://127.0.0.1:11434/v1

# Chat / vision LLM and text embedding model names (as shown by `ollama list`)
OLLAMA_CHAT_MODEL=qwen3.5:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Must match the embedding model output size (nomic-embed-text: 768, mxbai-embed-large: 1024)
EMBEDDING_DIMENSION=768

# Persistent data directory (use absolute path on VPS)
OPENVIKING_WORKSPACE=${HOME}/openviking_workspace_ollama

# HTTP bind (CLI flags; 0.0.0.0 on VPS behind firewall / reverse proxy)
OPENVIKING_HOST=127.0.0.1
OPENVIKING_PORT=1933

# Dummy key for OpenAI-compatible clients (Ollama ignores it)
OPENVIKING_VLM_API_KEY=ollama

OPENVIKING_LOG_LEVEL=INFO
OPENVIKING_VLM_MAX_CONCURRENT=20
OPENVIKING_EMBED_MAX_CONCURRENT=10

# Generated config path (default: under XDG_CACHE_HOME or ~/.cache)
# OPENVIKING_RUNTIME_DIR=/var/lib/openviking

# Use uvx to run server (default: 1). Set to 0 to use openviking-server on PATH
# OPENVIKING_USE_UVX=1
