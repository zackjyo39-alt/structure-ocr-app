{
  "server": {
    "host": "127.0.0.1",
    "port": 1933,
    "root_api_key": null,
    "cors_origins": ["*"]
  },
  "storage": {
    "workspace": "./runtime/data",
    "vectordb": {
      "backend": "local",
      "dimension": 768
    }
  },
  "log": {
    "level": "INFO",
    "output": "stdout"
  },
  "default_search_mode": "fast",
  "embedding": {
    "dense": {
      "provider": "ollama",
      "model": "nomic-embed-text",
      "api_base": "http://127.0.0.1:11434/v1",
      "dimension": 768
    },
    "max_concurrent": 10
  }
}
